# Database
DATABASE_URL=postgresql://user:password@localhost:5432/booking

# Server
PORT=3001
NODE_ENV=production

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBAPP_URL=https://your-miniapp.onrender.com
BACKEND_URL=https://your-backend.onrender.com

# Business
BUSINESS_ID=demo-business
ADMIN_TELEGRAM_ID=your_telegram_id

# Security
JWT_SECRET=generate_random_64_char_string_here
JWT_EXPIRES_IN=7d

# Slot Engine (optional)
SLOT_CACHE_DAYS=14
SLOT_CACHE_TTL_HOURS=24

# Docker (optional)
DB_USER=booking
DB_PASSWORD=booking123
DB_NAME=booking
DB_PORT=5432
BACKEND_PORT=3001
