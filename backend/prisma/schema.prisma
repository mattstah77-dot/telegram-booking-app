// Prisma Schema for Booking System
// PostgreSQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// BUSINESS CONFIGURATION
// ============================================

model Business {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String?
  phone       String?
  timezone    String   @default("Europe/Moscow")
  
  // Telegram
  botToken        String?  @map("bot_token")
  adminTelegramId String?  @map("admin_telegram_id")
  
  // Settings
  bufferMinutes      Int      @default(10) @map("buffer_minutes")
  maxDaysAhead       Int      @default(30) @map("max_days_ahead")
  minBookingMinutes  Int      @default(30) @map("min_booking_minutes")
  cancellationHours  Int      @default(2) @map("cancellation_hours")
  autoConfirm        Boolean  @default(true) @map("auto_confirm")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  services   Service[]
  schedule   Schedule[]
  breaks     Break[]
  bookings   Booking[]
  exceptions Exception[]
  slots      SlotCache[]
  
  @@map("businesses")
}

// ============================================
// SERVICES
// ============================================

model Service {
  id          String  @id @default(cuid())
  businessId  String  @map("business_id")
  
  name        String
  description String?
  
  // Pricing & Duration
  price           Int  @default(0)  // в копейках или минимальной единице
  durationMinutes Int  @map("duration_minutes")
  bufferMinutes   Int? @map("buffer_minutes")  // если null, используется из Business
  
  // Status & Order
  isActive Boolean @default(true) @map("is_active")
  order    Int     @default(0)
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings Booking[]
  
  @@index([businessId])
  @@index([businessId, isActive])
  @@map("services")
}

// ============================================
// SCHEDULE (Working Hours)
// ============================================

model Schedule {
  id         String @id @default(cuid())
  businessId String @map("business_id")
  
  // Day of week: 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  weekday Int // 0-6
  
  // Working hours
  isWorking Boolean @default(true) @map("is_working")
  startTime String  @map("start_time") // HH:mm format
  endTime   String  @map("end_time")   // HH:mm format
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@unique([businessId, weekday])
  @@index([businessId])
  @@map("schedule")
}

// ============================================
// BREAKS (Daily breaks like lunch)
// ============================================

model Break {
  id         String @id @default(cuid())
  businessId String @map("business_id")
  
  name String? // "Обед", "Перерыв"
  
  // Break time
  startTime String @map("start_time") // HH:mm format
  endTime   String @map("end_time")   // HH:mm format
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@index([businessId])
  @@map("breaks")
}

// ============================================
// EXCEPTIONS (Holidays, special days)
// ============================================

model Exception {
  id         String @id @default(cuid())
  businessId String @map("business_id")
  
  date DateTime @db.Date
  
  // Type: 'holiday' | 'closed' | 'special_hours'
  type String
  
  // For special_hours type
  openTime  String? @map("open_time")  // HH:mm
  closeTime String? @map("close_time") // HH:mm
  
  reason String? // "Новый год", "Ремонт"
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@unique([businessId, date])
  @@index([businessId])
  @@index([businessId, date])
  @@map("exceptions")
}

// ============================================
// BOOKINGS
// ============================================

model Booking {
  id         String @id @default(cuid())
  businessId String @map("business_id")
  serviceId  String @map("service_id")
  
  // Date & Time
  date      DateTime @db.Date
  startTime String   @map("start_time") // HH:mm
  endTime   String   @map("end_time")   // HH:mm
  
  // Client info
  clientName  String  @map("client_name")
  clientPhone String  @map("client_phone")
  telegramId  String? @map("telegram_id")
  
  // Status: pending | confirmed | cancelled | completed | no_show
  status String @default("pending")
  
  // Pricing (snapshot at booking time)
  serviceName String  @map("service_name")
  price       Int     // в копейках
  duration    Int     // в минутах
  
  // Cancellation
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledBy   String?   @map("cancelled_by")
  cancelReason  String?   @map("cancel_reason")
  
  // Reminders
  reminder24hSent Boolean @default(false) @map("reminder_24h_sent")
  reminder1hSent  Boolean @default(false) @map("reminder_1h_sent")
  
  // Notes
  notes String?
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id])
  
  @@index([businessId])
  @@index([businessId, date])
  @@index([businessId, date, status])
  @@index([serviceId])
  @@index([telegramId])
  @@map("bookings")
}

// ============================================
// SLOT CACHE (Pre-generated slots)
// ============================================

model SlotCache {
  id         String @id @default(cuid())
  businessId String @map("business_id")
  
  date DateTime @db.Date
  time String   // HH:mm
  
  // Slot info
  durationMinutes Int    @map("duration_minutes")
  endTime         String @map("end_time")
  
  // Availability
  isAvailable Boolean @default(true) @map("is_available")
  bookingId   String? @map("booking_id")
  
  // Cache metadata
  generatedAt DateTime @default(now()) @map("generated_at")
  expiresAt   DateTime @map("expires_at")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@unique([businessId, date, time])
  @@index([businessId, date])
  @@index([businessId, expiresAt])
  @@map("slot_cache")
}

// ============================================
// NOTIFICATION LOG
// ============================================

model NotificationLog {
  id         String @id @default(cuid())
  businessId String @map("business_id")
  bookingId  String? @map("booking_id")
  
  type String // 'booking_created', 'reminder_24h', 'reminder_1h', 'cancellation'
  
  telegramId String  @map("telegram_id")
  status     String  // 'sent', 'failed'
  error      String?
  
  sentAt DateTime @default(now()) @map("sent_at")
  
  @@index([businessId])
  @@index([bookingId])
  @@map("notification_logs")
}

// ============================================
// ADMIN SESSIONS (for admin panel access)
// ============================================

model AdminSession {
  id         String @id @default(cuid())
  businessId String @map("business_id")
  
  telegramId String  @map("telegram_id")
  token      String  @unique
  expiresAt  DateTime @map("expires_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([businessId])
  @@index([token])
  @@map("admin_sessions")
}
